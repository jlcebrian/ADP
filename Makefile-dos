
MODE=32

!ifeq MODE 32

CC    = wpp386
CL    = wcl386
OPTS  = -I=include -I=include\src-dos -bt=DOS -mf -zq -zm -xd -DVERSION=$VERSION 
OPTS += -D_STDCLIB -DHAS_PCX -DHAS_XMSG -DNO_BUFFERING
OPTIM = -otexan -zc -d0 -3 -r
LOPTS = -l=CAUSEWAY
OPTS  += -D_DEBUGPRINT
OPTS  += -DDEBUG_ALLOCS
UPX   = upx

#OPTIM=-od -d3 -hw
#OPTIM=-onatx -oh -ei -zp8 -3

!else

CC     = wpp
CL     = wcl
OPTS   = -I=include -I=include\src-dos -bt=DOS -ml -zq -zm -DVERSION=$VERSION 
OPTS  += -D_STDCLIB -DHAS_PCX -DHAS_XMSG -DNO_BUFFERING
OPTS  += -D_DEBUGPRINT
OPTS  += -DDEBUG_ALLOCS
OPTIM  = -d0 -otexan

!endif

OBJS = 		     &
	ddb_data.obj &
	ddb_inp.obj  &
	ddb_run.obj  &
	ddb_scr.obj  &
	ddb_vid.obj  &
	ddb.obj      &
	ddb_pal.obj  &
	ddb_play.obj &
	ddb_xmsg.obj &
	dmg.obj      &
	dmg_font.obj &
	dmg_pcx.obj  &
	dmg_cga.obj  &
	dmg_ega.obj  &
	dmg_cach.obj &
	dmg_imgc.obj &
	dmg_imgp.obj &
	dmg_rlec.obj &
	dmg_rleo.obj &
	dmg_rleop.obj &
	dmg_univ.obj &
	dmg_zx0.obj  &
	ddb_scr.obj  &
	os_file.obj  &
	os_char.obj  &
	os_lib.obj   &
	os_mem.obj   &
	scrfile.obj  &
	debug.obj    &
	dma.obj      &
	files.obj    &
	mixer.obj    &
	video.obj    &
	sb.obj       &
	timer.obj    &
	player.obj

Debug : all .SYMBOLIC
Release : all .SYMBOLIC
all : out/adp.exe .SYMBOLIC

clean
	@if exist *.obj             @rm *.obj
	@if exist src-common\*.obj  @rm src-common\*.obj
	@if exist src\dos\*.obj     @rm src\dos\*.obj
	@if exist *.err             @rm *.err
	@if exist src-common\*.err  @rm src-common\*.err
	@if exist src\dos\*.err     @rm src\dos\*.err
	@if exist adp.exe           @rm adp.exe
	@if exist objs.lnk          @rm objs.lnk

out/adp.exe: $OBJS 
	@echo OPTION ELIMINATE > objs.lnk
	@echo OPTION MAP >> objs.lnk
	@echo OPTION STACK=12K >> objs.lnk
	@for %i in ($(OBJS)) do @echo FILE %i >> objs.lnk
	$(CL) $(OPTS) $(OPTIM) $(LOPTS) -fe=$*.exe @objs.lnk
!ifdef UPX
	$(UPX) $*.exe >/dev/null
!endif

.obj: obj\dos
.cpp: src-common;src-dos
.cpp.obj: .AUTODEPEND
	$(CC) $(OPTIM) $(OPTS) -fo=$@ $<
