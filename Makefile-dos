!ifndef MODE
MODE = 32
!endif

EXE = adp$(MODE).exe

!ifndef OBJBUILD

OBJDIR = obj/dos$(MODE)
OUTDIR = out

Debug : .SYMBOLIC
	@if not exist $(OBJDIR) @mkdir $(OBJDIR)
	@cd $(OBJDIR) && wmake -h -f ../../Makefile-dos MODE=$(MODE) OBJBUILD=1 DEBUG=1 all

Release : .SYMBOLIC
	@if not exist $(OBJDIR) @mkdir $(OBJDIR)
	@cd $(OBJDIR) && wmake -h -f ../../Makefile-dos MODE=$(MODE) OBJBUILD=1 all

all : Release .SYMBOLIC

clean : .SYMBOLIC
	@if exist $(OBJDIR)/*.obj      @rm $(OBJDIR)/*.obj
	@if exist $(OBJDIR)/*.err      @rm $(OBJDIR)/*.err
	@if exist $(OBJDIR)/objs.lnk   @rm $(OBJDIR)/objs.lnk
	@if exist $(OUTDIR)/$(EXE)     @rm $(OUTDIR)/$(EXE)

!else

ROOT = ../..

!ifeq MODE 32

CC    = wpp386
CL    = wcl386
OPTS  = -I=$(ROOT)/include -I=$(ROOT)/include/src-dos -bt=DOS -mf -zq -zm -xd -DVERSION=$VERSION
OPTS += -D_STDCLIB -DHAS_PCX -DHAS_SPECTRUM -DHAS_XMSG -DNO_BUFFERING
OPTIM = -osexanuc -zc -3 -r
LOPTS = -l=CAUSEWAY
UPX   = upx
#OPTIM=-onatx -oh -ei -zp8 -3

!else

CC     = wpp
CL     = wcl
OPTS   = -I=$(ROOT)/include -I=$(ROOT)/include/src-dos -bt=DOS -ml -zq -zm -DVERSION=$VERSION
OPTS  += -D_STDCLIB -DHAS_PCX -DHAS_SPECTRUM -DHAS_XMSG -DNO_BUFFERING
OPTIM  = -osexanuc
UPX    = upx

!endif

!ifdef DEBUG
OPTS  += -D_DEBUGPRINT -DDEBUG_ALLOCS
OPTIM += -d1
!endif

OBJS = 		      &
	ddb_data.obj  &
	ddb_inp.obj   &
	ddb_run.obj   &
	ddb_scr.obj   &
	ddb_vid.obj   &
	ddb.obj       &
	ddb_pal.obj   &
	ddb_play.obj  &
	ddb_xmsg.obj  &
	dmg.obj       &
	dmg_font.obj  &
	dmg_pcx.obj   &
	dmg_cga.obj   &
	dmg_ega.obj   &
	dmg_cach.obj  &
	dmg_imgc.obj  &
	dmg_imgp.obj  &
	dmg_rlec.obj  &
	dmg_rleo.obj  &
	dmg_rleop.obj &
	dmg_univ.obj  &
	dmg_zx0.obj   &
	os_file.obj   &
	os_char.obj   &
	os_lib.obj    &
	os_mem.obj    &
	scrfile.obj   &
	debug.obj     &
	dma.obj       &
	files.obj     &
	mixer.obj     &
	video.obj     &
	sb.obj        &
	timer.obj     &
	player.obj

Debug : all .SYMBOLIC
Release : all .SYMBOLIC
all : $(ROOT)/out/$(EXE) .SYMBOLIC

clean : .SYMBOLIC
	@if exist *.obj     @rm *.obj
	@if exist *.err     @rm *.err
	@if exist objs.lnk  @rm objs.lnk

$(ROOT)/out/$(EXE): $(OBJS)
	@if not exist $(ROOT)/out @mkdir $(ROOT)/out
	@echo OPTION ELIMINATE > objs.lnk
	@echo OPTION MAP >> objs.lnk
	@echo OPTION STACK=12K >> objs.lnk
	@for %i in ($(OBJS)) do @echo FILE %i >> objs.lnk
	$(CL) $(OPTS) $(OPTIM) $(LOPTS) -fe=$@ @objs.lnk
!ifdef UPX
	$(UPX) $@ >/dev/null
!endif

.cpp: $(ROOT)/src-common;$(ROOT)/src-dos
.cpp.obj: .AUTODEPEND
	$(CC) $(OPTIM) $(OPTS) -fo=$@ $<

!endif
