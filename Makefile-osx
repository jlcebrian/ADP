VERSION    ?= BETA0.3

DEBUGPRINT ?= 1
DEBUGCACHE ?= 0
DEBUGALLOC ?= 1
DEBUGLTIME ?= 0
DEBUG      ?= 1
TRACE      ?= 0
OPTIM      ?= -O2

OBJDIR := obj/osx
OUTDIR := out
APPDIR := $(OUTDIR)/ADP.app
PLAYER_TARGET := $(OUTDIR)/player
TOOL_TARGETS := $(OUTDIR)/dmg $(OUTDIR)/chr $(OUTDIR)/ddb $(OUTDIR)/dsk

# Toolchain and macOS SDK/link settings.
CPPFLAGS += -D_OSX -D_THREAD_SAFE
CPPFLAGS += -arch arm64 -target macos11.0
LDFLAGS += -target macos11.0 -arch arm64
CPPFLAGS += -Ilib/sdl2/include
LDFLAGS += lib/osx/libSDL2.a lib/osx/libSDL2main.a
LDFLAGS += -lm -liconv -Wl,-framework,CoreAudio -Wl,-framework,AudioToolbox -Wl,-weak_framework,CoreHaptics -Wl,-weak_framework,GameController -Wl,-framework,ForceFeedback -lobjc -Wl,-framework,CoreVideo -Wl,-framework,Cocoa -Wl,-framework,Carbon -Wl,-framework,IOKit -Wl,-weak_framework,QuartzCore -Wl,-weak_framework,Metal

# Shared platform and feature configuration.
CPPFLAGS += -Iinclude -Iinclude-tools -Ilib-src/salvador
CPPFLAGS += -DVERSION=$(VERSION) -D_STDCLIB -D_UNIX
CPPFLAGS += -DHAS_CLIPBOARD -DHAS_VIRTUALFILESYSTEM -DHAS_FULLSCREEN
CPPFLAGS += -DHAS_SNAPSHOTS -DHAS_PAWS -DHAS_DRAWSTRING -DHAS_XMSG
CPPFLAGS += -DHAS_PCX -DHAS_SPECTRUM -DHAS_PSG
CPPFLAGS += -Dstricmp=strcasecmp -Dstrnicmp=strncasecmp

ifeq ($(DEBUGPRINT),1)
CPPFLAGS += -D_DEBUGPRINT
CPPFLAGS += -DDEBUG_IMAGE_CACHE=$(DEBUGCACHE)
endif
ifeq ($(DEBUGALLOC),1)
CPPFLAGS += -DDEBUG_ALLOCS=1
endif
ifeq ($(DEBUGLTIME),1)
CPPFLAGS += -DDEBUG_RLE -DDEBUG_ZX0
endif
ifeq ($(DEBUG),1)
CPPFLAGS += -g
endif
ifeq ($(TRACE),1)
CPPFLAGS += -DTRACE_DEBUG -DTRACE_ON
endif

CPPFLAGS += $(OPTIM)
CPPFLAGS += `libpng-config --cflags`
LDFLAGS += `libpng-config --ldflags`

DIRS := src-common/ lib-src/salvador/
VPATH := $(DIRS) src-sdl/ src-unix/ src-tools/
SRCS := $(wildcard $(addsuffix *.cpp,$(DIRS))) src-sdl/video.cpp
TOOL_SRCS := bas_cpc bas_zx dmg_edit dmg_pack img ddb_writ cli_parser session_commands
TOOL_MAIN_SRCS := $(wildcard src-tools/tool_*.cpp)

TOOL_CPPFLAGS = $(CPPFLAGS) -DTRACE_ON

COMMON_OBJS := $(addprefix $(OBJDIR)/,$(patsubst %.cpp,%.o,$(notdir $(SRCS))))
COMMON_OBJS += $(OBJDIR)/files.o $(OBJDIR)/error.o
PLAYER_OBJ := $(OBJDIR)/player.o
TOOL_OBJS := $(addprefix $(OBJDIR)/,$(addsuffix .o,$(TOOL_SRCS)))
TOOL_MAIN_OBJS := $(addprefix $(OBJDIR)/,$(patsubst %.cpp,%.o,$(notdir $(TOOL_MAIN_SRCS))))

.PHONY: all clean

-include $(COMMON_OBJS:.o=.d) $(PLAYER_OBJ:.o=.d) $(TOOL_OBJS:.o=.d) $(TOOL_MAIN_OBJS:.o=.d)

all: $(APPDIR) $(TOOL_TARGETS)

$(OUTDIR):
	@mkdir -p $@

$(APPDIR): $(PLAYER_TARGET) | $(OUTDIR)
	@mkdir -p $(APPDIR)/Contents/MacOS
	@mkdir -p $(APPDIR)/Contents/Resources
	@cp $(PLAYER_TARGET) $(APPDIR)/Contents/MacOS/ADP
	@cp lib/logo.icns $(APPDIR)/Contents/Resources/ADP.icns
	@cp lib/Info.plist $(APPDIR)/Contents/Info.plist

$(OUTDIR)/dmg: $(COMMON_OBJS) $(TOOL_OBJS) $(OBJDIR)/tool_dmg.o | $(OUTDIR)
	$(info Linking $@)
	@$(CXX) -o $@ $^ $(LDFLAGS)

$(OUTDIR)/chr: $(COMMON_OBJS) $(TOOL_OBJS) $(OBJDIR)/tool_chr.o | $(OUTDIR)
	$(info Linking $@)
	@$(CXX) -o $@ $^ $(LDFLAGS)

$(OUTDIR)/ddb: $(COMMON_OBJS) $(TOOL_OBJS) $(OBJDIR)/tool_ddb.o | $(OUTDIR)
	$(info Linking $@)
	@$(CXX) -o $@ $^ $(LDFLAGS)

$(OUTDIR)/dsk: $(COMMON_OBJS) $(TOOL_OBJS) $(OBJDIR)/tool_dsk.o | $(OUTDIR)
	$(info Linking $@)
	@$(CXX) -o $@ $^ $(LDFLAGS)

$(PLAYER_TARGET): $(COMMON_OBJS) $(PLAYER_OBJ) | $(OUTDIR)
	$(info Linking $@)
	@$(CXX) -o $@ $^ $(LDFLAGS)

clean:
	rm -f $(OBJDIR)/*.o $(OBJDIR)/*.d $(TOOL_TARGETS) $(PLAYER_TARGET)
	rm -rf $(APPDIR)

$(COMMON_OBJS) $(PLAYER_OBJ) : $(OBJDIR)/%.o : %.cpp
	$(info Compiling $<)
	@mkdir -p $(dir $@)
	@$(CC) $(CPPFLAGS) -c -o $@ "$(CURDIR)/$<"

$(TOOL_OBJS) : $(OBJDIR)/%.o : %.cpp
	$(info Compiling $<)
	@mkdir -p $(dir $@)
	@$(CC) $(TOOL_CPPFLAGS) -c -o $@ "$(CURDIR)/$<"

$(TOOL_MAIN_OBJS) : $(OBJDIR)/%.o : %.cpp
	$(info Compiling $<)
	@mkdir -p $(dir $@)
	@$(CC) $(TOOL_CPPFLAGS) -Iinclude-tools -c -o $@ "$(CURDIR)/$<"
