
VERSION    ?= BETA0.3
DEBUGPRINT ?= 1
LIBCMINI   ?= $(HOME)/libcmini
UPX        ?= 1
UPXFLAGS   ?= -q -5

PREFIX   = m68k-atari-mint-
CXX      = $(PREFIX)g++
CC       = $(PREFIX)gcc
STRIP    = $(PREFIX)strip
OBJDUMP  = $(PREFIX)objdump
NM       = $(PREFIX)nm
VASM     = vasmm68k_mot

OUTDIR := out/atarist
TARGET := $(OUTDIR)/ad.prg
DUMP   := $(OUTDIR)/player.dump

ifeq ($(UPX),1)
PACK_CMD = upx $(UPXFLAGS) $(TARGET) >/dev/null
else
PACK_CMD = true
endif

CPPFLAGS += -Iinclude -DVERSION=$(VERSION) -D_STDCLIB -D_ATARIST -DHAS_ASM_RLE -DHAS_DRAWTEXT -DHAS_XMSG
CPPFLAGS += -DNO_PRINTF -DNO_SAMPLES -DDEBUG_ALLOCS=1 -DDEBUG_MEMORY=0 -DNO_BUFFERING -D_BIG_ENDIAN
CPPFLAGS += -Dstricmp=strcasecmp -Dstrnicmp=strncasecmp 
ifeq ($(DEBUGPRINT),1)
CPPFLAGS += -D_DEBUGPRINT
endif
CPPFLAGS += -Os -fomit-frame-pointer -fno-rtti -fno-exceptions
CPPFLAGS += -include include/libcmini_cxx.h
CPPFLAGS += -I$(LIBCMINI)/include -nostdlib
CPPFLAGS += -Wall -Wno-unused-value
LDFLAGS += -nostdlib $(LIBCMINI)/lib/crt0.o
LIBS += -L$(LIBCMINI)/lib -lcmini -lgcc -lgem

VASMFLAGS = -m68000 -Felf -opt-fconst -nowarn=62 -quiet -x 

all: $(TARGET)

DIRS = src-common/ src-atarist/
VPATH = $(DIRS)
SRCS = $(wildcard $(addsuffix *.cpp,$(DIRS)))

CPPFILES := 		\
	ddb_data.cpp	\
	ddb_draw.cpp	\
	ddb_dump.cpp	\
	ddb_inp.cpp		\
	ddb_pal.cpp		\
	ddb_play.cpp	\
	ddb_run.cpp		\
	ddb_scr.cpp		\
	ddb_snap.cpp	\
	ddb_vid.cpp		\
	ddb_xmsg.cpp	\
	ddb.cpp			\
	dmg_cach.cpp	\
	dmg_cga.cpp		\
	dmg_ega.cpp		\
	dmg_imgc.cpp	\
	dmg_imgp.cpp	\
	dmg_rlec.cpp	\
	dmg_rleo.cpp	\
	dmg_rleop.cpp	\
	dmg_univ.cpp	\
	dmg_zx0.cpp	\
	dmg.cpp			\
	os_char.cpp 	\
	os_lib.cpp		\
	os_mem.cpp		\
	os_file.cpp		\
	scrfile.cpp		\
	textdraw.cpp	\
	files.cpp		\
	player.cpp		\
	video.cpp
ASMFILES :=			\
	decrle_old_planar8.asm	\
	decrle.asm		\
	audio.asm

CPPOBJS := $(patsubst %.cpp,obj/atarist/%.o,$(CPPFILES))
ASMOBJS := $(patsubst %.asm,obj/atarist/%.o,$(ASMFILES))

$(TARGET): $(CPPOBJS) $(ASMOBJS) | $(OUTDIR)
	$(CXX) $(LDFLAGS) $(CPPFLAGS) -o $@ $^ $(LIBS)
	$(OBJDUMP) -S $@ > $(DUMP)
	echo >> $(DUMP)
	echo ------------------------------------------------ >> $(DUMP)
	echo >> $(DUMP)
	$(STRIP) -x $@
	$(NM) --numeric-sort --print-size $@ >> $(DUMP)
	echo >> $(DUMP)
	echo ------------------------------------------------ >> $(DUMP)
	echo >> $(DUMP)
	$(NM) --print-size --size-sort --radix=d $@ >> $(DUMP)
	$(STRIP) $@
	$(PACK_CMD)
	@cd out && ./dsk atarist/original.st add atarist/ad.prg
	@cp out/atarist/ad.prg out/atarist/cozumel/
	@cp out/atarist/ad.prg out/atarist/original/

$(OUTDIR):
	mkdir -p $@

clean:
	rm -f obj/atarist/*.o $(TARGET) $(DUMP)

-include $(CPPOBJS:.o=.d)

$(CPPOBJS) : obj/atarist/%.o : %.cpp
	$(info Compiling $<)
	@$(CC) $(CPPFLAGS) -c -o $@ $(CURDIR)/$<
$(ASMOBJS) : obj/atarist/%.o : %.asm
	$(info Compiling $<)
	$(VASM) $(VASMFLAGS) -o $@ $(CURDIR)/$<
