# to generate assembler listing with LTO, add to LDFLAGS: -Wa,-adhln=$@.listing,--listing-rhs-width=200
# for better annotations add -dA -dP
# to generate assembler source with LTO, add to LDFLAGS: -save-temps=cwd

VERSION ?= BETA0.3
DEBUG_MEMORY ?= 0
DEBUGPRINT ?= 0
DEBUG_ALLOCS ?= 0

ifdef OS
	WINDOWS = 1
	SHELL = cmd.exe
endif

subdirs := src-amiga/ src-common/
VPATH = $(subdirs)
cpp_sources := $(wildcard *.cpp) $(wildcard $(addsuffix *.cpp,$(subdirs)))
cpp_objects := $(addprefix obj/amiga/,$(patsubst %.cpp,%.o,$(notdir $(cpp_sources))))
c_sources := $(wildcard *.c) $(wildcard $(addsuffix *.c,$(subdirs)))
c_objects := $(addprefix obj/amiga/,$(patsubst %.c,%.o,$(notdir $(c_sources))))
s_sources := $(wildcard $(addsuffix *.s, $(subdirs)))
s_objects := $(addprefix obj/amiga/,$(patsubst %.s,%.o,$(notdir $(s_sources))))
zx0_s_source := src-zx0/unzx0_68k.s
zx0_s_object := obj/amiga/unzx0_68k.o
zx0_fast_s_source := src-zx0/unzx0_68k_fast.s
zx0_fast_s_object := obj/amiga/unzx0_68k_fast.o
vasm_sources := $(wildcard *.asm) $(wildcard $(addsuffix *.asm, $(subdirs)))
vasm_objects := $(addprefix obj/amiga/, $(patsubst %.asm,%.o,$(notdir $(vasm_sources))))
objects := $(cpp_objects) $(c_objects) $(s_objects) $(zx0_s_object) $(zx0_fast_s_object) $(vasm_objects)

# https://stackoverflow.com/questions/4036191/sources-from-subdirectories-in-makefile/4038459
# http://www.microhowto.info/howto/automatically_generate_makefile_dependencies.html

exename = adp
program = out/amiga/$(exename)
OUT = $(program)
BOOTBLOCK = src-amiga/bootblock.bin
STARTUP_SEQUENCE = src-amiga/Startup-Sequence
FLOPPY_DIR = out/amiga/floppy
ADF_STAGE_DIR = out/amiga/adf-stage
ADF = $(OUT).adf
ADF_FORMAT ?= dd
ELF_DUMP = $(OUT).objdump
CC = m68k-amiga-elf-gcc
VASM = vasmm68k_mot
OBJDUMP = m68k-amiga-elf-objdump
#SHRINKLER = Shrinkler
SHRINKLER = cranker -q 
DSK = out/dsk

ifdef WINDOWS
	SDKDIR = $(abspath $(dir $(shell where $(CC)))..\m68k-amiga-elf\sys-include)
else
	SDKDIR = $(abspath $(dir $(shell which $(CC)))../m68k-amiga-elf/sys-include)
	TOOLBINDIR = $(abspath $(dir $(shell which $(CC))))
	TOOLSHIMDIR = $(CURDIR)/obj/amiga/.toolchain
	TOOLSHIM = $(TOOLSHIMDIR)/as
	TOOLPATH = PATH="$(TOOLSHIMDIR):$(TOOLBINDIR):$$PATH"
endif

CCFLAGS += -DVERSION=$(VERSION) 
CCFLAGS += -DDEBUG_MEMORY=$(DEBUG_MEMORY)
CCFLAGS += -DDEBUG_ALLOCS=$(DEBUG_ALLOCS)
CCFLAGS += -DNO_SAMPLES
CCFLAGS += -Os
ifeq ($(DEBUGPRINT),1)
CCFLAGS += -D_DEBUGPRINT
#CCFLAGS += -DDEBUG_IMAGE_CACHE
#CCFLAGS += -DDEBUG_FILE_CACHE
endif
CCFLAGS += -DHAS_ASM_RLE -DNO_BUFFERING -D_BIG_ENDIAN
CCFLAGS += -flto=6 -fwhole-program -Wno-attributes
CCFLAGS += -g -MP -MMD -m68000 -nostdlib 
CCFLAGS += -Wextra -Wno-unused-function -Wno-volatile-register-var 
CCFLAGS += -fno-tree-loop-distribution -fno-exceptions -fomit-frame-pointer 
CCFLAGS += -Iinclude -Isupport -D_AMIGA
CPPFLAGS= $(CCFLAGS) -fno-rtti -fcoroutines -fno-use-cxa-atexit
ASFLAGS = -Wa,-g,--register-prefix-optional,-I$(SDKDIR),-D
LDFLAGS = -Wl,--emit-relocs,-Ttext=0,-Map=$(OUT).map 
VASMFLAGS = -m68000 -Felf -opt-fconst -nowarn=62 -dwarf=3 -quiet -x -I. -I$(SDKDIR)

.PHONY: all clean adf

all: $(OUT).exe
adf: $(ADF)

ifndef WINDOWS
$(TOOLSHIM):
	@mkdir -p $(TOOLSHIMDIR)
	@ln -sf "$(TOOLBINDIR)/m68k-amiga-elf-as" "$(TOOLSHIM)"
endif

$(OUT).exe: $(OUT).elf
	$(info Elf2Hunk $(program).exe)
	@elf2hunk $(OUT).elf $(OUT).exe -s
	@$(SHRINKLER) $(OUT).exe $(OUT).exe

$(ADF_STAGE_DIR):
	mkdir -p "$(ADF_STAGE_DIR)/S"

$(ADF_STAGE_DIR)/S/Startup-Sequence: $(STARTUP_SEQUENCE) | $(ADF_STAGE_DIR)
	cp "$(STARTUP_SEQUENCE)" "$@"

$(ADF_STAGE_DIR)/ADP.EXE: $(OUT).exe | $(ADF_STAGE_DIR)
	cp "$(OUT).exe" "$@"

$(ADF): $(OUT).exe $(BOOTBLOCK) $(STARTUP_SEQUENCE) $(DSK) $(ADF_STAGE_DIR)/S/Startup-Sequence $(ADF_STAGE_DIR)/ADP.EXE
	$(info Building $(ADF))
	$(DSK) mkdisk $@ $(ADF_FORMAT)
	$(DSK) $@ setboot $(BOOTBLOCK)
	$(DSK) $@ addtree "$(FLOPPY_DIR)"
	$(DSK) $@ addtree "$(ADF_STAGE_DIR)"

$(OUT).elf: $(objects)
	$(info Linking $(program).elf)
ifndef WINDOWS
	@$(TOOLPATH) $(CC) $(CCFLAGS) $(LDFLAGS) $(objects) -o $@
	@$(TOOLPATH) $(OBJDUMP) --disassemble --no-show-raw-ins --visualize-jumps -S $@ >$(ELF_DUMP)
else
	@$(CC) $(CCFLAGS) $(LDFLAGS) $(objects) -o $@
	@$(OBJDUMP) --disassemble --no-show-raw-ins --visualize-jumps -S $@ >$(ELF_DUMP)
endif

clean:
	$(info Cleaning...)
ifdef WINDOWS
	@del /q obj\amiga\*.o obj\amiga\*.objdump out\amiga\$(exename).* out\amiga\$(exename).objdump
else
	@$(RM) obj/amiga/*.o obj/amiga/*.objdump obj/amiga/*.o.s out/amiga/$(exename).* out/amiga/$(exename).objdump
	@$(RM) -r "$(ADF_STAGE_DIR)"
endif

-include $(objects:.o=.d)

$(cpp_objects) : obj/amiga/%.o : %.cpp
	$(info Compiling $<)
ifndef WINDOWS
	@$(TOOLPATH) $(CC) $(CPPFLAGS) -c -o $@ $(CURDIR)/$<
else
	@$(CC) $(CPPFLAGS) -c -o $@ $(CURDIR)/$<
endif

$(c_objects) : obj/amiga/%.o : %.c
	$(info Compiling $<)
ifndef WINDOWS
	@$(TOOLPATH) $(CC) $(CCFLAGS) -c -o $@ $(CURDIR)/$<
else
	@$(CC) $(CCFLAGS) -c -o $@ $(CURDIR)/$<
endif

$(s_objects): obj/amiga/%.o : %.s
	$(info Assembling $<)
ifndef WINDOWS
	@$(TOOLPATH) $(CC) $(CCFLAGS) $(ASFLAGS) -c -o $@ $(CURDIR)/$<
else
	@$(CC) $(CCFLAGS) $(ASFLAGS) -c -o $@ $(CURDIR)/$<
endif

$(zx0_s_object): $(zx0_s_source)
	$(info Assembling $<)
	@$(VASM) $(VASMFLAGS) -o $@ $(CURDIR)/$<
ifndef WINDOWS
	@$(TOOLPATH) $(OBJDUMP) --disassemble-all --reloc $@ >$@.objdump
else
	@$(OBJDUMP) --disassemble-all --reloc $@ >$@.objdump
endif

$(zx0_fast_s_object): $(zx0_fast_s_source)
	$(info Assembling $<)
	@$(VASM) $(VASMFLAGS) -o $@ $(CURDIR)/$<
ifndef WINDOWS
	@$(TOOLPATH) $(OBJDUMP) --disassemble-all --reloc $@ >$@.objdump
else
	@$(OBJDUMP) --disassemble-all --reloc $@ >$@.objdump
endif

$(vasm_objects): obj/amiga/%.o : %.asm
	$(info Assembling $<)
	@$(VASM) $(VASMFLAGS) -o $@ $(CURDIR)/$<
ifndef WINDOWS
	@$(TOOLPATH) $(OBJDUMP) --disassemble-all --reloc $@ >$@.objdump
else
	@$(OBJDUMP) --disassemble-all --reloc $@ >$@.objdump
endif

ifndef WINDOWS
$(objects): | $(TOOLSHIM)
endif
